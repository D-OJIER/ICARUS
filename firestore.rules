rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net catch-all block
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Checks if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Validates formatted document identifiers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper: References incoming payload
    function incoming() {
      return request.resource.data;
    }

    // Helper: References existing stored document
    function existing() {
      return resource.data;
    }

    // 1. User Profile Collection rules
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Strict creation parameters validation
      allow create: if isSignedIn() && request.auth.uid == userId
        && incoming().keys().hasAll(['id', 'name', 'title', 'xp', 'streak', 'stats', 'earnedTitles'])
        && incoming().id == userId
        && incoming().name is string && incoming().name.size() <= 100
        && incoming().title is string && incoming().title.size() <= 100
        && incoming().xp is int && incoming().xp >= 0
        && incoming().streak is int && incoming().streak >= 0;

      // Allow updating specific metrics
      allow update: if isSignedIn() && request.auth.uid == userId
        && incoming().id == userId;
      allow delete: if false; // Profiles cannot be purloined or destroyed via client
    }

    // 2. User Quests Subcollection rules
    match /users/{userId}/quests/{questId} {
      allow read, list: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() && request.auth.uid == userId
        && isValidId(questId)
        && incoming().keys().hasAll(['id', 'title', 'difficulty', 'category', 'completed', 'createdAt'])
        && incoming().id == questId
        && incoming().title is string && incoming().title.size() <= 300
        && incoming().completed is bool;

      allow update: if isSignedIn() && request.auth.uid == userId
        && incoming().id == questId;

      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // 3. User Goals (Campaigns) Subcollection rules
    match /users/{userId}/goals/{goalId} {
      allow read, list: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() && request.auth.uid == userId
        && isValidId(goalId)
        && incoming().keys().hasAll(['id', 'title', 'status', 'createdAt'])
        && incoming().id == goalId
        && incoming().title is string && incoming().title.size() <= 300
        && incoming().status in ['In Quest', 'Triumphant', 'Abandoned'];

      allow update: if isSignedIn() && request.auth.uid == userId
        && incoming().id == goalId;

      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
