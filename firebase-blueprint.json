{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Pilgrim character sheet containing level, experience points, custom titles, and core attribute statistics",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifiers matching Firebase Auth UID" },
        "name": { "type": "string", "description": "Displays pilgrim's chosen public tag" },
        "title": { "type": "string", "description": "Active chosen title bestowed onto pilgrim" },
        "xp": { "type": "integer", "description": "Total earned experience points" },
        "streak": { "type": "integer", "description": "Active consecutive day alignment completed streak" },
        "avatarSeed": { "type": "string", "description": "Avatar geometric configuration seed" },
        "monumentSeed": { "type": "string", "description": "Starting alignment monument design" },
        "accountCreated": { "type": "string", "format": "date-time", "description": "Timestamp of registry" },
        "stats": { "type": "object", "description": "Dynamic attribute parameters e.g., Strength, Discipline..." },
        "chronicle": { "type": "array", "description": "Timeline log stories generated during AI examination" },
        "skillTrees": { "type": "array", "description": "Scribe-provided pathways and node states" },
        "achievements": { "type": "array", "description": "Earned milestones of sovereign capability" },
        "earnedTitles": { "type": "array", "description": "List of all titles awarded to this pilgrim" }
      },
      "required": ["id", "name", "title", "xp", "streak", "stats", "earnedTitles"]
    },
    "Quest": {
      "title": "Gothic Quest Record",
      "description": "Individual daily covenant or vow scheduled by user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Lesser Burden", "Sinuous Vow", "Mortal Penance"] },
        "category": { "type": "string", "enum": ["Vow", "Trial", "Crusade", "General", "Habit"] },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date" }
      },
      "required": ["id", "title", "difficulty", "category", "completed", "createdAt"]
    },
    "Goal": {
      "title": "Campaign Objective",
      "description": "Multi-stage long-term campaign designed by user and AI Mentor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "aspiration": { "type": "string" },
        "categoryName": { "type": "string" },
        "timelineExplanation": { "type": "string" },
        "resources": { "type": "array" },
        "stages": { "type": "array" },
        "status": { "type": "string", "enum": ["In Quest", "Triumphant", "Abandoned"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "linkedQuestsAdded": { "type": "boolean" }
      },
      "required": ["id", "title", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Document tracking each user's unique character metadata"
    },
    "/users/{userId}/quests/{questId}": {
      "schema": "Quest",
      "description": "Collection of individual user tasks and mental declarations"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "Collection of long-term structured campaigns tailored by AI"
    }
  }
}
